generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String        @id @default(cuid())
  name              String
  email             String        @unique
  username          String        @unique
  password          String
  avatar            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  refreshToken      String?       @unique
  globalRole        String        @default("USER")
  projects          ProjectMember[] @relation("UserProjects")
  assignedTasks     Task[]        @relation("AssignedTasks")
  reportedTasks     Task[]        @relation("ReportedTasks")
  comments          Comment[]
  notifications     Notification[]
}


model Project {
  id                String        @id @default(cuid())
  name              String
  description       String?
  archived          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  boards            Board[]
  members           ProjectMember[]
}


model Board {
  id                String        @id @default(cuid())
  name              String
  projectId         String        
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  columns           Column[]
}


model Column {
  id                String        @id @default(cuid())
  name              String
  order             Int           
  wipLimit          Int?
  boardId           String        
  board             Board         @relation(fields: [boardId], references: [id], onDelete : Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tasks             Task[]
  @@unique([boardId,order])
}


model Task {
  id                String        @id @default(cuid())
  title             String
  description       String?
  status            String        @default("TODO")
  priority          String        @default("MEDIUM")
  type              String        @default("TASK")
  assigneeId        String?
  assignee          User?       @relation("AssignedTasks", fields: [assigneeId], references: [id])
  reporterId        String
  reporter          User        @relation("ReportedTasks", fields: [reporterId], references: [id])
  dueDate           DateTime?
  columnId          String
  column            Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)
  parentId          String?
  parent            Task?         @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks          Task[]        @relation("SubTasks")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  auditLogs         AuditLog[]
  comments          Comment[]
  resolvedAt        DateTime?
  closedAt          DateTime?
  notifications     Notification[]
}


model AuditLog {
  id                String        @id @default(cuid())
  taskId            String
  task              Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId            String
  action            String
  oldValue          String?
  newValue          String?
  createdAt         DateTime      @default(now())
}



model Comment {
  id                String        @id @default(cuid())
  content           String
  taskId            String
  task              Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId          String
  author            User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
}



model Notification {
  id                String        @id @default(cuid())
  userId            String
  message           String
  read              Boolean       @default(false)
  taskId            String?
  taskTitle         String?
  createdAt         DateTime      @default(now())
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task              Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)

}



model ProjectMember {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation("UserProjects",fields: [userId], references: [id], onDelete: Cascade)
  projectId         String
  role              String        @default("VIEWER")
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}